# ============================================================
# Sellna.ai — Sales Agentic AI
# Free Local Stack: Ollama + sentence-transformers + Qdrant
# ============================================================

# --- App ---
APP_NAME="Sales Agentic AI"
ENVIRONMENT=development
DEBUG=false

# --- Security ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_EXPIRE_MINUTES=1440

# ============================================================
# LLM — pick ONE provider via LLM_PROVIDER, fill in only its *_API_KEY.
# Options: openai | grok | groq | openrouter | nvidia | gemini | ollama | custom
# ============================================================
LLM_PROVIDER=groq

# Shared LLM params
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# --- Groq — https://console.groq.com/keys ---
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile   # alt: mixtral-8x7b-32768, llama-3.1-8b-instant

# --- NVIDIA NIM — https://build.nvidia.com ---
NVIDIA_API_KEY=nvapi-your_key_here
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_THINKING=true                 # toggle reasoning mode for reasoning models
NVIDIA_REASONING_EFFORT=high         # "" | low | medium | high  (leave "" if model rejects it)

# --- OpenRouter — https://openrouter.ai/keys ---
OPENROUTER_API_KEY=sk-or-your_key_here
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# --- Google Gemini — https://aistudio.google.com/apikey ---
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- OpenAI — https://platform.openai.com/api-keys ---
OPENAI_API_KEY=sk-your_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (local, no API key needed) ---
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2    # pull with: ollama pull llama3.2

# ============================================================
# EMBEDDINGS — sentence-transformers (local, FREE, runs on CPU)
# ============================================================
EMBEDDING_BACKEND=sentence_transformers
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2   # 384 dims, ~90MB
EMBEDDING_DIMENSION=384

# ============================================================
# VECTOR DB — Qdrant (local Docker, FREE)
# ============================================================
VECTOR_STORE=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=sales_ai_embeddings

# ============================================================
# DATABASE — PostgreSQL
# ============================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sales_ai
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ============================================================
# QUEUE — Redis + Celery
# ============================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================================
# SCRAPING
# ============================================================
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=30
RETRY_TIMES=3
BROWSER_HEADLESS=true

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=console       # console | json

# ============================================================
# OBSERVABILITY (disable to skip prometheus dep)
# ============================================================
PROMETHEUS_ENABLED=false
PROMETHEUS_PATH=/metrics

# ============================================================
# PIPELINE
# ============================================================
PIPELINE_TIMEOUT_SECONDS=300

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================
# FRONTEND — Supabase (Vite reads this from repo root via envDir)
# ============================================================
VITE_SUPABASE_PROJECT_ID=your_supabase_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_URL=https://your_project_id.supabase.co
