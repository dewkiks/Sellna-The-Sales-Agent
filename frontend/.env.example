# Frontend environment — copy this file to .env.local and fill in real values.
# .env.local is gitignored; this .env.example is the committed template.
#
#   cp .env.example .env.local      (Windows: Copy-Item .env.example .env.local)

# --- Supabase — REQUIRED for sign-in / sign-up ---
# Without these, the app shows "Auth is not configured" and auth is disabled.
# Get both values from your Supabase project:
#   Supabase Dashboard → your project → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# --- Backend API (optional) ---
# Defaults to http://localhost:8001/api/v1 if omitted.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001/api/v1
