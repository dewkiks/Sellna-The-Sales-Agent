# Frontend environment — copy this file to .env.local and adjust as needed.
# .env.local is gitignored; this .env.example is the committed template.
#
#   cp .env.example .env.local      (Windows: Copy-Item .env.example .env.local)
#
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# --- Backend API ---
# Base URL of the FastAPI backend. Auth (JWT) and all data calls go here.
VITE_API_BASE_URL=http://localhost:8001/api/v1
